## 🔄 Workflow Coordination

### Task Handoff Protocol

```typescript
interface TaskHandoff {
    fromAgent: string;
    toAgent: string;
    taskId: string;
    completedDeliverables: string[];
    nextSteps: string[];
    contextTransfer: {
        codeChanges: string[];
        configUpdates: string[];
        testResults: string[];
        knownIssues: string[];
    };
}

// Example: DataLayerAgent (Roo) to UIRenderer handoff
const dataToUIHandoff: TaskHandoff = {
    fromAgent: "DataLayerAgent",
    toAgent: "UIRenderer",
    taskId: "gsh-dashboard-data-hooks",
    completedDeliverables: [
        "useGSHDocuments hook",
        "useAnalysisResults hook",
        "real-time subscriptions",
    ],
    nextSteps: [
        "Implement dashboard components",
        "Connect hooks to UI components",
        "Add loading and error states",
    ],
    contextTransfer: {
        codeChanges: ["services/gsh-data.service.ts"],
        configUpdates: ["query key definitions"],
        testResults: ["all hooks tests passing"],
        knownIssues: ["rate limiting on LlamaCloud queries"],
    },
};
```

### Parallel Task Execution

```typescript
// Execute independent tasks in parallel
const parallelTasks = [
    { agent: "PlanningArchitect", task: "design-api-architecture" },
    { agent: "DataLayerAgent", task: "define-query-strategies" },
    { agent: "RuleKeeper", task: "setup-testing-framework" },
];

// Sequential tasks with dependencies
const sequentialTasks = [
    { agent: "PlanningArchitect", task: "complete-api-design" },
    {
        agent: "UIRenderer",
        task: "implement-endpoints",
        dependencies: ["complete-api-design"],
    },
    {
        agent: "TaskTracker",
        task: "validate-integration",
        dependencies: ["implement-endpoints"],
    },
];
```

